source: completion_test.go
expression: stdout.String()
---
|
  name: mytool
  description: My tool
  persistentflags:
      -V, --version: Show version info for mytool
      -h, --help: Show help for mytool
  commands:
      - name: completion
        description: Output a carapace-spec YAML document to stdout
      - name: deploy
        description: Deploy commands
      - name: repo
        description: Repository commands
