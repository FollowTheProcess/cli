source: completion_test.go
expression: stdout.String()
---
|
  name: mytool
  description: My tool
  flags:
      --dry-run: Dry run, make no changes
      --tags=: Tags to apply
      --timeout=: Timeout in seconds
      -f, --force: Force the operation
      -o, --output=: Output file
      -v, --verbose*: Verbosity level
  persistentflags:
      -V, --version: Show version info for mytool
      -h, --help: Show help for mytool
  commands:
      - name: completion
        description: Output a carapace-spec YAML document to stdout
